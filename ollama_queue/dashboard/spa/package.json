{
  "name": "ollama-queue-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:css\" \"npm run dev:js\"",
    "dev:css": "npx @tailwindcss/cli -i src/index.css -o dist/bundle.css --watch",
    "dev:js": "node esbuild.config.mjs --watch",
    "build": "npm run build:css && npm run build:js",
    "build:css": "npx @tailwindcss/cli -i src/index.css -o dist/bundle.css --minify",
    "build:js": "node esbuild.config.mjs",
    "lint": "eslint .",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "@preact/signals": "^2.0.0",
    "preact": "^10.25.0",
    "superhot-ui": "file:../../../../superhot-ui",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@babel/preset-env": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "babel-jest": "^30.2.0",
    "concurrently": "^9.1.0",
    "esbuild": "^0.25.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.3.0",
    "tailwindcss": "^4.0.0"
  }
}
